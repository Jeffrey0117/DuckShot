{
  "name": "duckshot",
  "version": "1.1.2",
  "description": "DuckShot - 高畫質桌面截圖工具 (Electron)",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "test": "node --test \"tests/**/*.test.js\"",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Jeffrey0117/DuckShot.git"
  },
  "keywords": [
    "electron",
    "screenshot",
    "duckshot",
    "desktop",
    "windows"
  ],
  "author": "Jeffrey0117",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Jeffrey0117/DuckShot/issues"
  },
  "homepage": "https://github.com/Jeffrey0117/DuckShot",
  "devDependencies": {
    "clipboardy": "^4.0.0",
    "electron": "^38.1.2",
    "electron-builder": "^26.0.12",
    "electron-store": "^10.1.0"
  },
  "build": {
    "appId": "tw.duk.duckshot",
    "productName": "DuckShot",
    "directories": {
      "output": "dist"
    },
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "asarUnpack": [
      "node_modules/@gutenye/ocr-node/**",
      "node_modules/@gutenye/ocr-common/**",
      "node_modules/@gutenye/ocr-models/**",
      "node_modules/onnxruntime-node/**"
    ],
    "files": [
      "src/**/*",
      "renderer/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icons/app-icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DuckShot"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icons/app-icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icons/app-icon.png"
    }
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@gutenye/ocr-node": "^1.4.8",
    "jimp": "^1.6.1",
    "tesseract.js": "^5.1.1"
  }
}
